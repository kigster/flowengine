#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "flowengine"

HAVE_TTY = $stdout.tty? && $stderr.tty?

if HAVE_TTY
  require "tty-box"
  require "tty-prompt"
end

def error_box(message)
  if HAVE_TTY
    puts TTY::Box.error(message)
  else
    warn message
  end
end

begin
  client = FlowEngine::LLM.auto_client
rescue FlowEngine::Errors::LLMError => e
  error_box("ERROR: #{e.message}")
  exit 1
end

question = if HAVE_TTY
             prompt = TTY::Prompt.new(enable_color: true, active_color: :green)
             prompt.ask(" ❯❯ Please ask an LLM a question: ")
           else
             puts "Please ask an LLM a question: "
             $stdin.gets&.strip
             if question.nil? || question.empty?
               error_box("No question provided.")
               exit 1
             end
           end

begin
  response = client.adapter.chat(
    system_prompt: "You are a helpful assistant. Answer concisely.",
    user_prompt: question,
    model: client.model
  )
rescue FlowEngine::Errors::LLMError => e
  warn e.message
  exit 1
end

puts "\n#{response}"
